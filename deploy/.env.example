# yxpt deployment environment.
# Copy this file to deploy/.env and fill in real values.
# DO NOT commit deploy/.env (it's in .gitignore).

# --- Database (Postgres) ---
# Used by the `db` service to initialize the cluster, and by the `api` service
# (via DATABASE_URL) to connect. Keep POSTGRES_USER/PASSWORD/DB in sync.
POSTGRES_USER=yxpt
POSTGRES_PASSWORD=YOUR_PASSWORD_HERE    # generate with: openssl rand -base64 32
POSTGRES_DB=yxpt

# Connection string the api container uses. `db` is the docker-compose service
# name, resolved by docker's embedded DNS. Both `postgres:PARSE` and
# `postgresql:PARSE` URLs are accepted by the postgres driver.
DATABASE_URL=postgresql://yxpt:YOUR_PASSWORD_HERE@db:5432/yxpt

# --- Server ---
NODE_ENV=production
PORT=3000

# Optional: fastify logger level. One of trace|debug|info|warn|error|fatal.
# Default: info. Set to debug while developing; warn or error in production
# if logs are noisy.
LOG_LEVEL=info

# Random string reserved for future admin endpoints. Define it now so the
# stack is ready when those routes land. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=YOUR_ADMIN_TOKEN_HERE
